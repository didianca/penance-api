{
  "name": "penance-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GraphQL API for the Penance TCG demo.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx scripts/seed.ts",
    "dynamodb:local": "dynalite --port 8000",
    "dynamodb:ui": "dynamodb-admin"
  },
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "@aws-sdk/client-dynamodb": "^3.1004.0",
    "@aws-sdk/lib-dynamodb": "^3.1004.0",
    "dotenv": "^17.2.3",
    "graphql": "^16.11.0",
    "uuid": "^13.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "dynalite": "^4.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
